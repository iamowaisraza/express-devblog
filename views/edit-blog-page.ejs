<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DevBlog</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <div class="container form-container">
      <div class="page-header">
        <h1>Edit Post</h1>
        <a href="/post/<%= id %>" class="btn-sm">⬅ Cancel</a>
      </div>

      <div class="form-group">
        <label>Title</label>
        <input type="text" id="title" name="title" value="<%= title %>" required />
      </div>

      <div class="form-group">
        <label>Author</label>
        <input type="text" id="author" name="author" value="<%= author %>" required />
      </div>

      <div class="form-group">
        <label>Content</label>
        <textarea id="content" name="content" rows="6" required><%= content %></textarea>
      </div>

      <button type="submit" class="btn warning" onclick="return updatePost('<%= id %>');">Update Post</button>
    </div>

    <script src="/js/script.js"></script>
  </body>
</html>
