<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DevBlog</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <div class="container form-container">
      <div class="page-header">
        <h1>Create New Post</h1>
        <a href="/" class="btn-sm">⬅ Back</a>
      </div>

      <div class="form-group">
        <label>Title</label>
        <input
          type="text"
          id="title"
          name="title"
          placeholder="Enter post title"
          minlength="5"
          maxlength="100"
          required
        />
      </div>

      <div class="form-group">
        <label>Author</label>
        <input
          type="text"
          id="author"
          name="author"
          placeholder="Enter author name"
          minlength="3"
          maxlength="50"
          required
        />
      </div>

      <div class="form-group">
        <label>Content</label>
        <textarea
          id="content"
          name="content"
          rows="6"
          placeholder="Write your content..."
          minlength="20"
          required
        ></textarea>
      </div>

      <button type="submit" class="btn" onclick="return createPost();">Publish Post</button>
    </div>

    <script src="/js/script.js"></script>
  </body>
</html>
